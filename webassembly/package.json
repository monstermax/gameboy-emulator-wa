{
  "name": "gameboy-emulator-webassembly",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "npm run asbuild:release && cp -a build/* ../web/public/webassembly/",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release && cp -a build/* ../web/public/webassembly/",
    "asbuild:debug": "asc assembly/index.ts --transform json-as --target debug",
    "asbuild:release": "asc assembly/index.ts --transform json-as --target release",
    "start": "npx serve ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "assemblyscript": "^0.28.9"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./build/release.js",
      "types": "./build/release.d.ts"
    }
  },
  "dependencies": {
    "json-as": "^1.2.6"
  }
}
